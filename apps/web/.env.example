# ─────────────────────────────────────────────────────────────
# NIS web app (apps/web) — environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it's in .gitignore.
# ─────────────────────────────────────────────────────────────

# Public site URL (used in emails + OG metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PLOS web app URL (used by the header "Sign in" button + "Open PLOS" CTA).
# In production this is https://app.thenispace.com.
NEXT_PUBLIC_PLOS_URL=http://localhost:5173

# ─── Analytics (Plausible) ───────────────────────────────────────────
# Set to your Plausible site key (usually the bare domain, e.g. thenispace.com)
# to enable the script tag. Leave empty in dev — no script gets rendered.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=thenispace.com
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# ─── Rate limiting (Upstash Redis REST) ──────────────────────────────
# Without these, /api/waitlist + /api/razorpay/* fall back to an
# in-memory limiter that's fine for dev but doesn't share state across
# Vercel functions. Get from https://console.upstash.com → Create Database.
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AAA...

# ─── Razorpay ────────────────────────────────────────────────
# Dashboard → Settings → API Keys → Generate Test Key
# https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Webhooks → Add. Subscribe to payment.captured.
RAZORPAY_WEBHOOK_SECRET=

# ─── Supabase ────────────────────────────────────────────────
# Project Settings → API
# Run apps/web/supabase/schema.sql in the SQL editor first.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SERVICE ROLE — bypasses RLS. Never expose in a NEXT_PUBLIC_ var.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Storage bucket holding tracker files (.xlsx etc.). Default: products
SUPABASE_PRODUCTS_BUCKET=products

# ─── Admin dashboard (/admin/orders) ─────────────────────────
# HTTP Basic Auth for the /admin area. Leave BOTH unset to disable the admin
# area entirely (it 404s). Set both to turn it on; use a long random password.
# ADMIN_USER=ishank
# ADMIN_PASSWORD=

# ─── Resend (transactional email) ────────────────────────────
# https://resend.com — verify your domain before sending live.
RESEND_API_KEY=re_xxxxxxxxxxxxxx
RESEND_FROM_EMAIL=NIS <notifications@thenispace.com>
