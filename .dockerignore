# Local dev artefacts — never copied into image
node_modules
**/node_modules
.next
**/.next
.git
.gitignore
.gitattributes
**/.DS_Store

# NOTE: plos-backend and plos-frontend are NOT excluded — the plos-frontend
# image needs them (and their workspace deps) in its build context, and
# plos-backend uses its own ./plos-backend context. The nis-web Dockerfile
# only COPYs apps/web + packages/*, so leaving these dirs in the context
# is fine (a small unused build-context cost; not copied into the image).

# Docs / planning / agent metadata
docs
graphify-out
.claude
.cursor
.cursorrules
.github
.vscode
.idea
*.md
!apps/web/README.md

# Tests
playwright-report
test-results
**/tests
**/*.spec.ts

# Local env files (never bake secrets into images)
.env
.env.local
**/.env
**/.env.local

# Build cache
**/tsconfig.tsbuildinfo
