{
  "name": "plos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "kill-port 3001 5173 && concurrently -k -n backend,frontend -c blue,magenta \"npm run start:dev --prefix plos-backend\" \"npm run dev --prefix plos-frontend\"",
    "dev:web": "npm run dev --workspace=apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "kill-port": "^2.0.1"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
