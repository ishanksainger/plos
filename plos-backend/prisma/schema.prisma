generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  name            String?
  passwordHash    String?
  /** Set when the user clicks the verification link. Null = unverified. */
  emailVerifiedAt DateTime?
  timezone        String    @default("Asia/Kolkata")
  currency        String    @default("INR")
  /** Optional — WhatsApp / SMS reminders (Step J) */
  phone           String?
  /** solo | family | shared — roadmap H; permissions model in a later step */
  accountType     String    @default("solo")
  createdAt       DateTime  @default(now())

  persons                Person[]
  responsibilities       Responsibility[]
  notifications          Notification[]
  subscription           Subscription?
  notificationPrefs      NotificationPreferences?
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

/** Short-lived, single-use token for the /reset-password flow. */
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/** Token mailed at signup; clicking marks `User.emailVerifiedAt`. */
model EmailVerificationToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/**
 * Per-user toggles for the four notification surfaces. A row is created
 * lazily on first GET if missing; defaults match the prior hardcoded UI.
 */
model NotificationPreferences {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])
  inAppEnabled  Boolean  @default(true)
  emailDigests  Boolean  @default(false)
  whatsappOptIn Boolean  @default(false)
  streakAtRisk  Boolean  @default(true)
  updatedAt     DateTime @default(now()) @updatedAt
}

model Person {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  name        String
  email       String
  phone       String?
  avatarUrl   String?
  relation    String    // self, father, mother, partner, child, sibling, other
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())

  responsibilities Responsibility[]
}

model Responsibility {
  id          Int       @id @default(autoincrement())
  title       String
  category    String    // finance, health, habit, family, admin
  module      String?   // finance, health, habits, family
  dueDate     DateTime
  completedAt DateTime?
  amount      Decimal?  @db.Decimal(12, 2)
  recurrence  String    @default("none") // none, daily, weekly, monthly, yearly
  notes       String?
  createdAt   DateTime  @default(now())

  userId   Int
  user     User    @relation(fields: [userId], references: [id])
  personId Int?
  person   Person? @relation(fields: [personId], references: [id])

  events        Event[]
  notifications Notification[]
}

model Event {
  id               Int      @id @default(autoincrement())
  responsibilityId Int
  fromState        String
  toState          String
  note             String?
  occurredAt       DateTime @default(now())

  responsibility Responsibility @relation(fields: [responsibilityId], references: [id])
}

model Notification {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id])
  responsibilityId Int?
  responsibility   Responsibility? @relation(fields: [responsibilityId], references: [id])
  type             String    // state_change, reminder, digest
  channel          String    // in_app, email, whatsapp, push
  status           String    @default("pending") // pending, sent, failed
  sentAt           DateTime?
  title            String    @default("")
  message          String?
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Subscription {
  id                 Int       @id @default(autoincrement())
  userId             Int       @unique
  user               User      @relation(fields: [userId], references: [id])
  tier               String    @default("free") // free, pro
  status             String    @default("active") // active, cancelled, expired
  razorpayCustomerId String?
  razorpaySubId      String?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
}
