DATABASE_URL="postgresql://user:password@host:5432/plos"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development

# Public URL of the PLOS frontend — used in password-reset + verification
# email link bodies. Defaults to http://localhost:5173 if unset.
PLOS_APP_URL="http://localhost:5173"

# Transactional email (password reset, email verification). Without these
# the MailerService logs the link to the server log so dev still works.
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="PLOS <notifications@thenispace.com>"

# Scheduler: unset = every 1 min (dev) / every 5 min (production). Override with cron syntax.
# SCHEDULER_CRON=*/5 * * * *
# Streaks-at-risk: defaults every 30 min (dev) / every hour (prod).
# STREAK_RISK_CRON="0 13,18 * * *"

# Optional error monitoring (leave unset locally)
# SENTRY_DSN=
# LOG_LEVEL=info

# Set to true to skip inserting `[PLOS seed]` placeholders on first `/users/dashboard` when the account has zero responsibilities.
# DISABLE_DASHBOARD_DUMMY_SEED=true

# Optional: email for `prisma db seed` (see package.json -> prisma.seed). Must be an existing user.
# Seeds dashboard sample responsibilities and events after you register that account locally.
# SEED_EMAIL="you@example.com"
