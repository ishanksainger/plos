DATABASE_URL="postgresql://user:password@host:5432/plos"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# Set to true to skip inserting `[PLOS seed]` placeholders on first `/users/dashboard` when the account has zero responsibilities.
# DISABLE_DASHBOARD_DUMMY_SEED=true

# Optional: email for `prisma db seed` (see package.json -> prisma.seed). Must be an existing user.
# Seeds dashboard sample responsibilities and events after you register that account locally.
# SEED_EMAIL="you@example.com"
